# Copy to `.env` and adjust per environment. Vite only exposes vars prefixed with VITE_.

# Base URL of the backend REST API. The Axios client prepends this to every request.
VITE_API_BASE_URL=http://localhost:8000/api

# When "true", services resolve to in-memory mock adapters instead of hitting the API.
# Backend integration = flip this to "false"; no UI changes required.
VITE_USE_MOCKS=true
